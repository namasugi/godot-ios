# App Store Connect API 認証情報（Apple Developer アカウント単位・全アプリ共通）。
# これをコピーして ~/.appstoreconnect/asc_auth.env を作成し、各値を記入する。
# このファイル(.env)と *.p8 は絶対にリポジトリへコミットしないこと（public 公開時は特に厳守）。
#
# 取得元: App Store Connect → ユーザーとアクセス → 統合(Integrations) → App Store Connect API
#   - キー発行時に表示される "キー ID" → ASC_KEY_ID
#   - ページ上部の "Issuer ID"        → ASC_ISSUER_ID
#   - ダウンロードした AuthKey_XXXX.p8 の保存先 → ASC_KEY_PATH

ASC_KEY_ID="XXXXXXXXXX"
ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ASC_KEY_PATH="~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"
